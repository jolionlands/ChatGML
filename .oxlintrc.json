{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "oxc"],
  "env": {
    "es2024": true,
    "node": true
  },
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**",
    "vscode/node_modules/**",
    "vscode/dist/**",
    "talk_codebase/**",
    "plugin/**",
    "vscode/**",
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-debugger": "error",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrors": "none"
      }
    ],
    "eqeqeq": ["error", "smart"],
    "no-var": "error",
    "prefer-const": "error",
    "no-throw-literal": "error",
    "typescript/no-explicit-any": "warn",
    "typescript/no-non-null-assertion": "off",
    "typescript/consistent-type-imports": "off"
  }
}
